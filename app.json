{
  "expo": {
    "name": "SpotBroo",
    "slug": "SpotBroo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mgatzwei.SpotBroo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mgatzwei.SpotBroo",
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.BACKGROUND_FETCH"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "SpotBroo",
              "label": "SpotBroo Prices",
              "minWidth": "250dp",
              "minHeight": "120dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "description": "Shows current electricity spot price and hourly chart",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      [
        "expo-widgets",
        {
          "ios": {
            "bundleIdentifier": "com.mgatzwei.SpotBroo.widgets",
            "groupIdentifier": "group.com.mgatzwei.SpotBroo"
          },
          "widgets": [
            {
              "name": "SpotBrooWidget",
              "displayName": "SpotBroo Prices",
              "description": "Shows current electricity spot price and hourly chart",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge"
              ]
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1b4c96ff-112b-40d9-bfdc-356e0e8a8f41"
      }
    }
  }
}
